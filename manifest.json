{
  "id": "tedi.ai-usage",
  "name": "AI Usage Meter",
  "version": "0.1.6",
  "description": "Shows Claude Code and Codex (ChatGPT) usage in the status bar as a progress bar with a detail tooltip: the 5-hour rolling window and the weekly limit for each, plus a reset countdown. Each meter can be hidden from Settings. Reads your local CLI credentials/sessions; the only network call is to Claude's own usage endpoint.",
  "author": "IlhamRiski - ilhamriski.com",
  "homepage": "https://tedi.ilhamriski.com/",
  "icon": "logo.png",
  "main": "extension.js",
  "permissions": [
    "statusbar:write",
    "settings:read",
    "settings:write",
    "ui:toast",
    "invoke:fs_read_file",
    "invoke:fs_glob",
    "invoke:shell_run_command"
  ],
  "engines": {
    "tedi": ">=0.3.9"
  },
  "contributes": {
    "settings": [
      {
        "id": "claudeAccount",
        "type": "note",
        "label": "Claude Code account",
        "default": "Not signed in"
      },
      {
        "id": "showClaude",
        "type": "boolean",
        "label": "Show Claude Code meter",
        "default": true,
        "description": "5-hour and weekly usage."
      },
      {
        "id": "codexAccount",
        "type": "note",
        "label": "Codex (ChatGPT) account",
        "default": "Not signed in"
      },
      {
        "id": "showCodex",
        "type": "boolean",
        "label": "Show Codex (ChatGPT) meter",
        "default": true,
        "description": "Usage windows by plan."
      }
    ]
  }
}
